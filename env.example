# Bub environment example
# Copy to `.env` and fill values.

# ---------------------------------------------------------------------------
# Agent runtime
# ---------------------------------------------------------------------------
# Republic model format: provider:model_id
# Default in code is `openrouter:qwen/qwen3-coder-next`.
# BUB_MODEL=openrouter:qwen/qwen3-coder-next
# BUB_MAX_STEPS=50
# BUB_MAX_TOKENS=1024
# BUB_MODEL_TIMEOUT_SECONDS=300
# BUB_HOME=~/.bub

# ---------------------------------------------------------------------------
# API keys (choose one)
# ---------------------------------------------------------------------------
# `AgentSettings` reads `BUB_API_KEY` and `BUB_API_BASE` directly.
# Provider-specific keys such as `OPENROUTER_API_KEY` may still be used by
# the underlying SDK/provider setup, but are not read by Bub settings itself.

# Preferred explicit key
# BUB_API_KEY=sk-...

# Optional custom API base
# BUB_API_BASE=https://openrouter.ai/api/v1

# Optional upstream API shape:
# - completion: legacy completion-style requests (default)
# - responses: OpenAI Responses API
# - messages: chat-completions-style messages API
# BUB_API_FORMAT=completion

# ---------------------------------------------------------------------------
# Channel manager
# ---------------------------------------------------------------------------
# Comma-separated channel names, or `all`.
# `all` excludes the builtin `cli` channel.
# BUB_ENABLED_CHANNELS=all
# BUB_DEBOUNCE_SECONDS=1.0
# BUB_MAX_WAIT_SECONDS=10.0
# BUB_ACTIVE_TIME_WINDOW=60.0

# ---------------------------------------------------------------------------
# WeChat QClaw bridge channel (optional)
# ---------------------------------------------------------------------------
# Local OpenAI-compatible bridge used by QClaw / OpenClaw.
# BUB_WECHAT_QCLAW_HOST=127.0.0.1
# BUB_WECHAT_QCLAW_PORT=8124

# ---------------------------------------------------------------------------
# Bub Codex plugin (optional)
# ---------------------------------------------------------------------------
# Enable a dedicated code/projects root for `bub-codex`.
# `bub-codex` reuses Codex's own `CODEX_HOME/config.toml` or `~/.codex/config.toml`.
#
# Recommended:
# - In Feishu/Lark main conversations, use `,codex.new`
# - Continue Codex work only inside the created topic thread
#
# BUB_CODEX_COMMAND=codex
# BUB_CODEX_PROJECTS_ROOT=/Users/you/code
# BUB_CODEX_STATE_DIR=~/.bub/codex
# BUB_CODEX_ENABLED_CHANNELS=lark
# BUB_CODEX_PANEL_UPDATE_DEBOUNCE_SECONDS=1.0
#
# Optional if your Codex config is not under `~/.codex`:
# CODEX_HOME=~/.codex

# ---------------------------------------------------------------------------
# Lark / Feishu channel (optional)
# ---------------------------------------------------------------------------
# BUB_LARK_APP_ID=
# BUB_LARK_APP_SECRET=
# BUB_LARK_DOMAIN=feishu
# Set this when your document links should open on a different docs host,
# for example international tenants using docs.larksuite.com.
# BUB_LARK_DOCS_HOST=docs.larksuite.com
# BUB_LARK_CONNECTION_MODE=websocket

# ---------------------------------------------------------------------------
# Websearch plugin (optional)
# ---------------------------------------------------------------------------
# Unified web search with provider fallback.
# The global order is persisted, but you can still provide a default here.
# BUB_WEBSEARCH_ENABLED=true
# BUB_WEBSEARCH_ENABLED_CHANNELS=
# BUB_WEBSEARCH_DEFAULT_ORDER=tavily,google_pse
# BUB_WEBSEARCH_ORDER_STORE_PATH=~/.bub/websearch/provider_order.json
# BUB_WEBSEARCH_REQUEST_TIMEOUT_SECONDS=15
# BUB_WEBSEARCH_TAVILY_API_KEY=
# BUB_WEBSEARCH_GOOGLE_PSE_API_KEY=
# BUB_WEBSEARCH_GOOGLE_PSE_CX=

# ---------------------------------------------------------------------------
# Stitch plugin (optional)
# ---------------------------------------------------------------------------
# Enable the plugin on all inbound channels by default.
# BUB_STITCH_ENABLED=true
# BUB_STITCH_ENABLED_CHANNELS=
#
# Official Stitch MCP endpoint.
# BUB_STITCH_BASE_URL=https://stitch.googleapis.com/mcp
#
# Optional local runtime settings.
# BUB_STITCH_NODE_COMMAND=node
# BUB_STITCH_NPM_COMMAND=npm
# BUB_STITCH_COMMAND_TIMEOUT_SECONDS=300
# BUB_STITCH_ARTIFACTS_DIR=~/.bub/stitch/artifacts
# BUB_STITCH_STATE_DIR=~/.bub/stitch/sessions
#
# Stitch authentication: choose exactly one mode
#
# Mode A: API key
# STITCH_API_KEY=
#
# Mode B: OAuth
# Leave STITCH_API_KEY empty when using OAuth.
# STITCH_ACCESS_TOKEN=
# GOOGLE_CLOUD_PROJECT=
#
# Notes:
# - Official Stitch SDK auth contract is:
#   1. `STITCH_API_KEY`
#   2. or (`STITCH_ACCESS_TOKEN` + `GOOGLE_CLOUD_PROJECT`)
# - `BUB_STITCH_API_KEY`, `BUB_STITCH_ACCESS_TOKEN`, and
#   `BUB_STITCH_PROJECT_ID` also work as plugin-scoped overrides if needed.
#
# ---------------------------------------------------------------------------
# Telegram channel (optional)
# ---------------------------------------------------------------------------
# BUB_TELEGRAM_TOKEN=123456:telegram-bot-token
# Comma-separated values:
# BUB_TELEGRAM_ALLOW_USERS=123456789,my_username
# BUB_TELEGRAM_ALLOW_CHATS=123456789,-1001234567890
# BUB_TELEGRAM_PROXY=http://127.0.0.1:1080

# ---------------------------------------------------------------------------
# Example minimal OpenRouter setup
# ---------------------------------------------------------------------------
# BUB_MODEL=openrouter:qwen/qwen3-coder-next
# BUB_API_KEY=sk-or-...

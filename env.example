# Bub environment example
# Copy to `.env` and fill values.

# ---------------------------------------------------------------------------
# Agent runtime
# ---------------------------------------------------------------------------
# Model format: provider:model_id
# BUB_MODEL=openrouter:qwen/qwen3-coder-next
# API transport mode:
# - auto: enable provider defaults, currently prefers OpenAI Responses when available
# - chat: force standard chat/completions style requests
# - responses: force OpenAI Responses API
# - native: use the provider's native transport
# BUB_API_MODE=chat
# BUB_MAX_STEPS=50
# BUB_MAX_TOKENS=1024
# BUB_MODEL_TIMEOUT_SECONDS=300
# BUB_HOME=~/.bub

# ---------------------------------------------------------------------------
# API access
# ---------------------------------------------------------------------------
# Bub reads these two variables directly.
# BUB_API_KEY=sk-...

# Optional custom API base.
# For OpenAI-compatible gateways:
# - `chat` usually targets `${BUB_API_BASE}/chat/completions`
# - `responses` usually targets `${BUB_API_BASE}/responses`
# If your gateway expects `/v1/responses`, include `/v1` in `BUB_API_BASE`.
# BUB_API_BASE=https://openrouter.ai/api/v1

# ---------------------------------------------------------------------------
# Channel manager
# ---------------------------------------------------------------------------
# Comma-separated channel names, or `all`.
# `all` excludes the builtin `cli` channel.
# BUB_ENABLED_CHANNELS=all
# BUB_DEBOUNCE_SECONDS=1.0
# BUB_MAX_WAIT_SECONDS=10.0
# BUB_ACTIVE_TIME_WINDOW=60.0

# ---------------------------------------------------------------------------
# Social coding plugin
# ---------------------------------------------------------------------------
# Install the plugin into Bub's environment first, for example:
#   cd /path/to/bub
#   uv pip install -e ../bub-social-coding
# BUB_SOCIAL_CODING_REPOS_FILE=/Users/you/code/repos.yaml
# BUB_SOCIAL_CODING_DB_PATH=/Users/you/.bub/social_coding.db
# BUB_SOCIAL_CODING_ALLOWED_ROOTS=/Users/you/code
# BUB_SOCIAL_CODING_ALLOW_REPO_REGISTRATION=true
# BUB_SOCIAL_CODING_ADMIN_ACTORS=wecom:your-user-id,telegram:your-user-id
# BUB_SOCIAL_CODING_ADMIN_CHATS=wecom_longconn_bot:your-chat-id,telegram:your-chat-id

# ---------------------------------------------------------------------------
# Telegram channel
# ---------------------------------------------------------------------------
# BUB_TELEGRAM_TOKEN=123456:telegram-bot-token
# BUB_TELEGRAM_ALLOW_USERS=123456789,my_username
# BUB_TELEGRAM_ALLOW_CHATS=123456789,-1001234567890
# BUB_TELEGRAM_PROXY=http://127.0.0.1:1080

# ---------------------------------------------------------------------------
# Lark / Feishu channel
# ---------------------------------------------------------------------------
# Install the plugin into Bub's environment first, for example:
#   cd /path/to/bub
#   uv pip install -e ../bub-lark
#
# Common settings:
# BUB_LARK_APP_ID=cli_xxx
# BUB_LARK_APP_SECRET=your-app-secret
# BUB_LARK_DOMAIN=feishu
# BUB_LARK_CONNECTION_MODE=websocket
# BUB_LARK_ALLOW_USERS=ou_xxx,u_xxx
# BUB_LARK_ALLOW_CHATS=oc_xxx
# BUB_LARK_AUTO_RECONNECT=true
# BUB_LARK_READY_TIMEOUT_SECONDS=5
# BUB_LARK_DOWNLOAD_MAX_BYTES=2097152
# BUB_LARK_DEBUG_OUTBOUND=true
#
# Webhook mode only:
# BUB_LARK_VERIFICATION_TOKEN=verification-token
# BUB_LARK_ENCRYPT_KEY=encrypt-key
# BUB_LARK_WEBHOOK_HOST=127.0.0.1
# BUB_LARK_WEBHOOK_PORT=8080
# BUB_LARK_WEBHOOK_PATH=/lark/events
# BUB_LARK_DEBUG_OUTBOUND=true

# ---------------------------------------------------------------------------
# WeCom webhook channel (outbound-only)
# ---------------------------------------------------------------------------
# BUB_WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx
# BUB_WECOM_WEBHOOK_TIMEOUT_SECONDS=10

# ---------------------------------------------------------------------------
# WeCom long-connection bot
# ---------------------------------------------------------------------------
# Builtin Node bridge mode:
# BUB_WECOM_LONGCONN_BOT_ID=your-bot-id
# BUB_WECOM_LONGCONN_SECRET=your-secret
#
# Optional: override the bridge process.
# BUB_WECOM_LONGCONN_COMMAND=
# BUB_WECOM_LONGCONN_NODE_COMMAND=node
# BUB_WECOM_LONGCONN_NPM_COMMAND=npm
# BUB_WECOM_LONGCONN_READY_TIMEOUT_SECONDS=5
# BUB_WECOM_LONGCONN_MOCK=false
#
# Optional provisioning / callback configuration.
# BUB_WECOM_LONGCONN_PAIRING_CODE=pairing-code
# BUB_WECOM_LONGCONN_CONFIG_KEY=config-key
# BUB_WECOM_LONGCONN_CALLBACK_TOKEN=callback-token
# BUB_WECOM_LONGCONN_ENCODING_AES_KEY=encoding-aes-key
# BUB_WECOM_LONGCONN_WEBSOCKET_URL=wss://example.invalid/ws

# ---------------------------------------------------------------------------
# Example minimal OpenRouter setup
# ---------------------------------------------------------------------------
# BUB_MODEL=openrouter:qwen/qwen3-coder-next
# BUB_API_MODE=chat
# BUB_API_KEY=sk-or-...

# ---------------------------------------------------------------------------
# Example OpenAI Responses setup
# ---------------------------------------------------------------------------
# BUB_MODEL=openai:gpt-4.1-mini
# BUB_API_MODE=responses
# BUB_API_KEY=sk-...
# BUB_API_BASE=https://api.openai.com/v1

# ---------------------------------------------------------------------------
# Example Anthropic-native setup
# ---------------------------------------------------------------------------
# BUB_MODEL=anthropic:claude-sonnet-4-5
# BUB_API_MODE=native
# BUB_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Example Gemini-native setup
# ---------------------------------------------------------------------------
# BUB_MODEL=gemini:gemini-2.5-pro
# BUB_API_MODE=native
# BUB_API_KEY=...

# ---------------------------------------------------------------------------
# Example Lark / Feishu websocket setup
# ---------------------------------------------------------------------------
# BUB_ENABLED_CHANNELS=lark
# BUB_LARK_APP_ID=cli_xxx
# BUB_LARK_APP_SECRET=your-app-secret
# BUB_LARK_DOMAIN=feishu
# BUB_LARK_CONNECTION_MODE=websocket
# BUB_LARK_DEBUG_OUTBOUND=true

# ---------------------------------------------------------------------------
# Example Lark / Feishu webhook setup
# ---------------------------------------------------------------------------
# BUB_ENABLED_CHANNELS=lark
# BUB_LARK_APP_ID=cli_xxx
# BUB_LARK_APP_SECRET=your-app-secret
# BUB_LARK_DOMAIN=lark
# BUB_LARK_CONNECTION_MODE=webhook
# BUB_LARK_VERIFICATION_TOKEN=verification-token
# BUB_LARK_ENCRYPT_KEY=encrypt-key
# BUB_LARK_WEBHOOK_HOST=127.0.0.1
# BUB_LARK_WEBHOOK_PORT=8080
# BUB_LARK_WEBHOOK_PATH=/lark/events
# BUB_LARK_DEBUG_OUTBOUND=true

# ---------------------------------------------------------------------------
# Example WeCom webhook setup
# ---------------------------------------------------------------------------
# BUB_ENABLED_CHANNELS=wecom_webhook
# BUB_WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxx

# ---------------------------------------------------------------------------
# Example WeCom long-connection bot setup
# ---------------------------------------------------------------------------
# BUB_ENABLED_CHANNELS=wecom_longconn_bot
# BUB_WECOM_LONGCONN_BOT_ID=your-bot-id
# BUB_WECOM_LONGCONN_SECRET=your-secret
